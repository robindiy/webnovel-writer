#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
PYTHON_EXEC="$REPO_ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON_EXEC" ]]; then
  echo "ERROR: Missing virtualenv at $REPO_ROOT/.venv" >&2
  echo "Run: $REPO_ROOT/scripts/bootstrap_env.sh" >&2
  exit 1
fi

exec "$PYTHON_EXEC" "$@"
